# Section 1: Load Target GND IDs
import pandas as pd
import lxml.etree as ET

# Template Paths - Update these to your local data folder
excel_path = "../data/target_gnd_ids.xlsx"
gnd_xml_path = "../data/authorities-gnd-koerperschaft.xml"
output_excel_path = "../outputs/extracted_project_records.xlsx"

print(f"✅ Loading GND IDs from '{excel_path}'...")
df_ids = pd.read_excel(excel_path)

# Extract IDs from the relevant column (adjust 'GND-ID' if your column name differs)
# We use a set for O(1) lookup speed
target_ids = set(df_ids['GND-ID'].dropna().astype(str).unique())
print(f"✅ Loaded {len(target_ids)} unique IDs to search for.")

# Section 2: Optimized XML Stream Processing
# We use iterparse to process the XML record-by-record without loading the whole 5GB+ file into RAM
extracted_records_data = []
records_processed = 0

print(f"✅ Starting optimized processing of MARCXML file...")

try:
    context = ET.iterparse(gnd_xml_path, events=('end',), tag='{http://www.loc.gov/MARC21/slim}record')
    
    for event, element in context:
        records_processed += 1
        
        # Extract GND ID from Control Field 001
        gnd_id = None
        id_field = element.find(".//{http://www.loc.gov/MARC21/slim}controlfield[@tag='001']")
        if id_field is not None:
            gnd_id = id_field.text.strip()

        # If this record is in our target list, extract the name (Field 110/111)
        if gnd_id in target_ids:
            project_name = ""
            # Look for Corporate/Project Name in 110 or 111
            name_field = element.find(".//{http://www.loc.gov/MARC21/slim}datafield[@tag='110']") or \
                         element.find(".//{http://www.loc.gov/MARC21/slim}datafield[@tag='111']")
            
            if name_field is not None:
                subfields = [sub.text for sub in name_field.findall("{http://www.loc.gov/MARC21/slim}subfield") if sub.text]
                project_name = " ".join(subfields)

            extracted_records_data.append({
                'GND-ID': gnd_id,
                'Project Name': project_name
            })
            
            if len(extracted_records_data) % 10 == 0:
                print(f"🔎 Found {len(extracted_records_data)} matches so far...")

        # CRITICAL: Clear the element from memory after processing
        element.clear()
        while element.getprevious() is not None:
            del element.getparent()[0]

    # Section 3: Export Results
    df_output = pd.DataFrame(extracted_records_data)
    df_output.to_excel(output_excel_path, index=False)
    print(f"✅ Success! Extracted {len(df_output)} records to {output_excel_path}")

except Exception as e:
    print(f"❌ Error during processing: {e}")
